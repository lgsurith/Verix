# GitHub App credentials
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# Server
PORT=3000

# Database (Neon Postgres or any Postgres)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Model config — pick one provider, set its key
MODEL_PROVIDER=gemini   # gemini | ollama | claude | openai

# Gemini
GEMINI_API_KEY=

# Ollama (local, no key needed)
# OLLAMA_URL=http://ollama:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# Claude (Anthropic)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Agent mode (set to false for one-shot prompt mode)
# VERIX_AGENT_MODE=true

# Smee webhook proxy (local dev only, remove in production)
# WEBHOOK_PROXY_URL=https://smee.io/your-channel
